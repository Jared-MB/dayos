{
  "name": "@dayos/core",
  "version": "0.0.0",
  "description": "A windowed desktop for React, with no opinion on styling or routing.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "react-rnd": "10.5.3",
    "tailwind-merge": "3.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsdown": "0.22.12",
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  }
}
