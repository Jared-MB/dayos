{
  "name": "@dayos/next",
  "version": "0.2.0",
  "description": "DayOS adapter for the Next App Router: windows with URLs of their own.",
  "keywords": [
    "react",
    "next",
    "nextjs",
    "app-router",
    "desktop",
    "window",
    "routing",
    "dayos"
  ],
  "homepage": "https://github.com/Jared-MB/dayos/tree/main/packages/next#readme",
  "bugs": "https://github.com/Jared-MB/dayos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jared-MB/dayos.git",
    "directory": "packages/next"
  },
  "license": "MIT",
  "author": "Jared Muñoz <amunozbaez669@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "tsdown",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@dayos/core": "workspace:^",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@dayos/core": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsdown": "0.22.12",
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  }
}
